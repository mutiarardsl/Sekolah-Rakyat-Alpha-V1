# ─── SR MVP Environment Variables ─────────────────────────────────────────────
# Salin file ini ke .env dan sesuaikan nilainya.

# ── Backend API ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000


# ── MSW Mock Service Worker ──────────────────────────────────────────────────
# "true" → intercept semua API dengan mock response
VITE_USE_MSW=true

# ── Feature Flags ─────────────────────────────────────────────────────────────
VITE_MENTOR_STREAM=false
VITE_EMOTION_API=false

# ── WebSocket (Fase 3) ────────────────────────────────────────────────────────
# "true"  → gunakan WebSocket nyata ke backend (Fase 3)
# "false" → dummy mode via setInterval (Fase 2, default)
VITE_USE_WS=false
VITE_WS_URL=ws://localhost:8000/ws
